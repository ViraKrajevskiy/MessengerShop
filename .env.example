# ─────────────────────────────────────────────────────────────────
#  .env.example — скопируй в .env и заполни свои значения
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# Django
DEBUG=False
SECRET_KEY=замени-на-длинный-случайный-ключ
ALLOWED_HOSTS=твой-домен.com,www.твой-домен.com

# Модераторский секретный ключ (для входа в /moderator/login)
MODERATOR_SECRET_KEY=замени-на-секретный-ключ-модератора

# Google OAuth (Client ID из console.cloud.google.com)
VITE_GOOGLE_CLIENT_ID=

# ── База данных PostgreSQL ────────────────────────────────────────
POSTGRES_DB=messhop
POSTGRES_USER=messhop
POSTGRES_PASSWORD=замени-на-сложный-пароль

# ── Email / SMTP ──────────────────────────────────────────────────
# Если оставить пустым — письма будут выводиться только в консоль
# Gmail: включи 2FA → App Password → 16-значный ключ
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
